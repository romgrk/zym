{
  "name": "zym-editor",
  "version": "0.1.0",
  "description": "A modal source-code editor built with GTK 4, Adwaita and GtkSourceView 5, on node-gtk",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./plugin-api": "./src/plugin-api.ts"
  },
  "bin": {
    "zym": "bin/zym.mjs"
  },
  "scripts": {
    "start": "pnpm run generate-icons && NODE_ENV=development node --import node-gtk/register src/index.ts",
    "install-desktop": "node scripts/install-desktop.ts",
    "prepare": "pnpm run generate-types && pnpm run generate-icons",
    "generate-icons": "node scripts/generate-icons.ts",
    "poc": "node --import node-gtk/register src/poc/fold-highlight.ts",
    "poc:inline": "node --import node-gtk/register src/poc/inline-overlay.ts",
    "poc:fullwidth": "node --import node-gtk/register src/poc/fullwidth-content-band.ts",
    "poc:peek": "node --import node-gtk/register src/poc/sibling-peek.ts",
    "poc:mdwidget": "node --import node-gtk/register src/poc/markdown-widget.ts",
    "poc:conversation": "node --import node-gtk/register src/poc/conversation-transcript.ts",
    "poc:combobox": "node --import node-gtk/register src/poc/combobox-gallery.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "node --import node-gtk/register --test 'src/**/*.test.ts' 'plugins/**/*.test.ts'",
    "test:sdk": "node --import node-gtk/register --test 'src/agents/claude-sdk/*.test.ts'",
    "generate-types": "node-gtk generate-types Gtk-4.0 Gio-2.0 Adw-1 GtkSource-5 Vte-3.91"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "color-bits": "^1.1.1",
    "diff": "^9.0.0",
    "marked": "^18.0.5",
    "native-keymap": "^3.3.9",
    "node-gtk": "^3.0.0",
    "outdent": "^0.8.0",
    "postcss-selector-parser": "^7.1.4",
    "tree-sitter-wasms": "^0.1.13",
    "vscode-jsonrpc": "^9.0.0",
    "vscode-languageserver-protocol": "^3.18.0",
    "web-tree-sitter": "^0.20.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@typescript-eslint/utils": "^8.61.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "typescript-language-server": "^5.3.0"
  }
}
