{
  "name": "quilx",
  "version": "0.1.0",
  "description": "A modal source-code editor built with GTK 4, Adwaita and GtkSourceView 5, on node-gtk",
  "license": "MIT",
  "type": "module",
  "main": "src/editor.ts",
  "bin": {
    "quilx": "src/editor.ts"
  },
  "scripts": {
    "start": "node src/editor.ts",
    "poc": "node src/poc/fold-highlight.ts",
    "typecheck": "tsc --noEmit",
    "generate-types": "node-gtk generate-types Gtk-4.0 Adw-1 GtkSource-5"
  },
  "dependencies": {
    "node-gtk": "link:../node-gtk"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tree-sitter-wasms": "^0.1.13",
    "typescript": "^6.0.3",
    "web-tree-sitter": "^0.20.8"
  }
}
