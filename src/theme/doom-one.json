{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Doom One",
  "author": "quilx",
  "themes": [
    {
      "name": "doom-one",
      "appearance": "dark",
      "style": {
        "background": "#2d2d2d",
        "foreground": "#bbc2cf",
        "border": "#434346",
        "editor.background": "#2d2d2d",
        "editor.foreground": "#bbc2cf",
        "editor.line_number": "#888888",
        "editor.active_line_number": "#bbc2cf",
        "syntax": {
          "comment": { "color": "#73797e" },
          "operator": { "color": "#51afef" },
          "punctuation": { "color": "#51afef" },
          "punctuation.special": { "color": "#da8548" },
          "string": { "color": "#98be65" },
          "string.regex": { "color": "#4db5bd" },
          "string.escape": { "color": "#c678dd" },
          "number": { "color": "#ff6c6b" },
          "boolean": { "color": "#ff6c6b" },
          "constant.builtin": { "color": "#da8548" },
          "constant": { "color": "#a9a1e1" },
          "variable.special": { "color": "#a9a1e1" },
          "variable.parameter": { "color": "#5699AF" },
          "attribute": { "color": "#ECBE7B" },
          "tag": { "color": "#51afef" },
          "keyword": { "color": "#51afef" },
          "property": { "color": "#c678dd" },
          "type": { "color": "#ECBE7B" },
          "constructor": { "color": "#ECBE7B" },
          "function": { "color": "#ECBE7B" }
        }
      }
    }
  ]
}
