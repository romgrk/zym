{
  "$schema": "./theme.schema.json",
  "name": "quilx",
  "appearance": "dark",
  "ui": {
    "editor.foreground": "#f1f1f1",
    "editor.background": "#2d2d2d",
    "editor.lineNumber": "#888888",
    "text.muted": "#5b6268",
    "text.accent": "#c678dd",
    "border": "#434346",
    "surface.popover": "#383838",
    "surface.selected": "#3f4b5b",
    "status.success": "#98be65",
    "status.warning": "#ecbe7b",
    "status.error": "#ff6c6b",
    "status.info": "#51afef",
    "status.hint": "#4db5bd",
    "search.match": "#e5a50a26",
    "search.match.current": "#e5a50a59"
  },
  "syntax": {
    "comment": { "color": "#80878c" },
    "operator": { "color": "#5ab9f9" },
    "punctuation": { "color": "#5ab9f9" },
    "punctuation.special": { "color": "#e69052" },
    "string": { "color": "#a3c970" },
    "string.regex": { "color": "#59c2ca" },
    "string.escape": { "color": "#cf80e6" },
    "number": { "color": "#ff7b7a" },
    "boolean": { "color": "#ff7b7a" },
    "constant.builtin": { "color": "#e69052" },
    "constant": { "color": "#afa7e7" },
    "variable.special": { "color": "#afa7e7" },
    "variable.parameter": { "color": "#62a6bc" },
    "attribute": { "color": "#f4c682" },
    "tag": { "color": "#5ab9f9" },
    "keyword": { "color": "#5ab9f9" },
    "property": { "color": "#cf80e6" },
    "type": { "color": "#f4c682" },
    "constructor": { "color": "#f4c682" },
    "function": { "color": "#f4c682" }
  }
}
